{
  "name": "skysh-saltbread",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "configure:extension": "node scripts/sync-extension-config.mjs",
    "dev:frontend": "next dev",
    "dev:ai_server": "cd ai_server && ./venv/bin/python -m uvicorn app.main:app --port 8000 --env-file ../.env.local",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:ai_server\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:extension": "node --test tests/*.test.js"
},
  "dependencies": {
    "firebase": "^12.15.0",
    "firebase-admin": "^14.1.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "overrides": {
    "jose": "5.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
