{
  "manifest_version": 3,
  "name": "불씨",
  "description": "불씨 서비스에 로그인하고 계정을 관리합니다.",
  "version": "1.0.0",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": ["cookies", "storage", "tabs", "alarms"],
  "host_permissions": [
    "__APP_MATCH_PATTERN__",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://api.upbit.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "__APP_MATCH_PATTERN__",
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  },
  "action": {
    "default_title": "불씨",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://upbit.com/exchange*",
        "https://www.upbit.com/exchange*"
      ],
      "js": ["upbit-debug-bridge-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://upbit.com/exchange*",
        "https://www.upbit.com/exchange*",
        "http://localhost/*",
        "http://127.0.0.1/*",
        "__APP_MATCH_PATTERN__"
      ],
      "js": ["config.js", "flame-animation.js", "data-core.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
