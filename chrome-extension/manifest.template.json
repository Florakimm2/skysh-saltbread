{
  "manifest_version": 3,
  "name": "Fireguard",
  "description": "Fireguard 서비스에 로그인하고 계정을 관리합니다.",
  "version": "1.0.0",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": ["alarms", "storage", "tabs"],
  "host_permissions": [
    "__APP_MATCH_PATTERN__",
    "https://api.upbit.com/*"
  ],
  "action": {
    "default_title": "Fireguard",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://upbit.com/exchange*",
        "https://www.upbit.com/exchange*",
        "__APP_MATCH_PATTERN__"
      ],
      "js": ["config.js", "cute-idle-flame.js", "data-core.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
