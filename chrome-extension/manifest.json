{
  "manifest_version": 3,
  "name": "Bulssi",
  "description": "업비트 주문 전 감정적 매매 패턴을 감지하고 사이드바 경고 및 쿨다운을 통해 올바른 투자 결정을 돕는 서비스입니다.",
  "version": "1.0.0",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": ["alarms", "storage", "tabs"],
  "host_permissions": [
    "https://skysh-saltbread.vercel.app/*",
    "https://api.upbit.com/*"
  ],
  "action": {
    "default_title": "Bulssi",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://upbit.com/exchange*",
        "https://www.upbit.com/exchange*",
        "http://localhost:3000/*",
        "https://skysh-saltbread.vercel.app/*"
      ],
      "js": ["config.js", "cute-idle-flame.js", "data-core.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
